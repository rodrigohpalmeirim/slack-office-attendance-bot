SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token
SLACK_SIGNING_SECRET=your-signing-secret
INITIAL_ADMIN_IDS=U12345,U67890
DATABASE_PATH=./data/attendance.db

# --- Companion web page (optional; all four required to enable it) ---
# "Sign in with Slack" OAuth credentials (OAuth & Permissions page)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
# Public HTTPS base URL the web page is served at (no trailing slash).
# Used for the OAuth redirect (PUBLIC_URL/auth/callback) and weekly DM links.
PUBLIC_URL=https://attendance.example.com
# Secret used to sign session cookies — set to a long random string.
SESSION_SECRET=
# Port the web server listens on (behind your reverse proxy). Default 3000.
WEB_PORT=3000
# Optional: restrict sign-in to a single Slack workspace/team ID.
SLACK_TEAM_ID=
